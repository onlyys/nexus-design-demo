{
  "version": 3,
  "routes": [
    {
      "src": "^/_next/static/(?:[^/]+/pages|pages|chunks|runtime|css|image|media|ouVElibCNSGlLCLX0hEJS)/.+",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "^/(.*)\\/$",
      "headers": {
        "Location": "/$1"
      },
      "status": 308
    },
    {
      "src": "^/?$",
      "has": [
        {
          "type": "header",
          "key": "rsc",
          "value": "1"
        }
      ],
      "dest": "/index.rsc",
      "headers": {
        "vary": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
        "content-type": "text/x-component"
      },
      "continue": true
    },
    {
      "src": "^/(.+?)(?:/)?$",
      "exclude": "\\.rsc/?$",
      "has": [
        {
          "type": "header",
          "key": "rsc",
          "value": "1"
        }
      ],
      "dest": "/$1.rsc",
      "headers": {
        "vary": "RSC, Next-Router-State-Tree, Next-Router-Prefetch, Next-Router-Segment-Prefetch",
        "content-type": "text/x-component"
      },
      "continue": true
    },
    {
      "src": "^/404/?$",
      "status": 404,
      "continue": true,
      "missing": [
        {
          "type": "header",
          "key": "x-prerender-revalidate"
        }
      ]
    },
    {
      "src": "^/500$",
      "status": 500,
      "continue": true
    },
    {
      "src": "^/((?:[^/]+/)*[^/.]+)/$",
      "dest": "/$1",
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/topic/([^/]+?)(?:/)?$"
    },
    {
      "src": "^/.*$"
    }
  ],
  "framework": {
    "version": "14.2.18"
  }
}